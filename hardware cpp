#include <WiFi.h>
#include <HTTPClient.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include "DHT.h"
#include <ArduinoJson.h>
#include <esp_system.h>

// ================== CONFIGURATION ==================
#define DHTPIN 4
#define DHTTYPE DHT11

const char* ssid = "Abinash_DHInternet";
const char* password = "DHInternet@21149598";

// Your backend API endpoint
const char* serverUrl = "http://192.168.18.63:8000/api/readings/";

// Shared token for device ingestion (same on all ESP32 boards)
const char* deviceToken = "CHANGE_ME_SHARED_DEVICE_TOKEN";

// ================== OBJECTS ==================
DHT dht(DHTPIN, DHTTYPE);
LiquidCrystal_I2C lcd(0x27, 16, 2);
String deviceUid;

String getDeviceUid() {
  uint64_t chipId = ESP.getEfuseMac();
  char buffer[17];
  snprintf(buffer, sizeof(buffer), "%04X%08X", (uint16_t)(chipId >> 32), (uint32_t)chipId);
  return String(buffer);
}

void setup() {
  Serial.begin(115200);
  dht.begin();
  deviceUid = getDeviceUid();
  
  // Initialize LCD
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("ATMONODE BOOTING");

  // Connect to WiFi
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected!");
  Serial.print("Device UID: ");
  Serial.println(deviceUid);
  lcd.clear();
  lcd.print("WiFi Online");
  delay(2000);
}

void loop() {
  // 1. Read Sensors
  float h = dht.readHumidity();
  float t = dht.readTemperature();

  if (isnan(h) || isnan(t)) {
    Serial.println("Failed to read from DHT sensor!");
    return;
  }

  // 2. Update Local LCD
  lcd.setCursor(0, 0);
  lcd.print("Temp: "); lcd.print(t);lcd.print((char)223); lcd.print("C  ");
  lcd.setCursor(0, 1);
  lcd.print("Hum : "); lcd.print(h); lcd.print("%  ");

  // 3. Send Data to Django
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    
    // Start connection
    http.begin(serverUrl);
    
    // Add Headers
    http.addHeader("Content-Type", "application/json");
    http.addHeader("X-Device-Token", deviceToken);

    // Create JSON Payload
    StaticJsonDocument<200> doc;
    doc["device_uid"] = deviceUid;
    doc["temperature"] = t;
    doc["humidity"] = h;

    String requestBody;
    serializeJson(doc, requestBody);

    // POST the data
    int httpResponseCode = http.POST(requestBody);

    // 4. Handle Response
    if (httpResponseCode > 0) {
      Serial.print("HTTP Response code: ");
      Serial.println(httpResponseCode);
      if(httpResponseCode == 201) {
         Serial.println("Data saved successfully in Django!");
      }
    } else {
      Serial.print("Error code: ");
      Serial.println(httpResponseCode);
    }

    http.end();
  }

  delay(10000); // Wait 10 seconds before next update
}
